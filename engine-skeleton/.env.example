# FinOps Watch AI Engine — Local Development Config
# Copy to .env and adjust values as needed.
# Production values are injected via ECS task definition / Secrets Manager.

FINOPS_APP_VERSION=0.1.0-skeleton
FINOPS_ENVIRONMENT=development
FINOPS_HOST=0.0.0.0
FINOPS_PORT=8080

# Detection tuning
FINOPS_CONFIDENCE_THRESHOLD=0.6
FINOPS_DEFAULT_CADENCE_HOURS=24
FINOPS_COST_SPIKE_MULTIPLIER=2.0

# Safety boundaries (DO NOT CHANGE)
FINOPS_NEVER_TERMINATE_PROD=true
FINOPS_NEVER_DELETE_DATA=true
FINOPS_NEVER_MODIFY_IAM=true
FINOPS_ALLOWED_CONTAINMENT_ENVS=["dev","sandbox","test"]

# Feature flags
FINOPS_ENABLE_LLM_ANALYSIS=false
FINOPS_ENABLE_AUTO_CONTAINMENT=false
FINOPS_DRY_RUN_MODE=true

# Audit
FINOPS_AUDIT_RETENTION_DAYS=90

# AWS / Bedrock (W12)
FINOPS_BEDROCK_MODEL_ID=anthropic.claude-haiku-4-5-20251001
FINOPS_BEDROCK_REGION=ap-southeast-1
FINOPS_AWS_REGION=ap-southeast-1

# Logging
FINOPS_LOG_LEVEL=INFO
