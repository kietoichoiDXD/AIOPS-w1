# Copy to .env and adjust for your environment
# Never commit .env to git

MOCK_ANOMALY_PROBABILITY=0.80
MOCK_MAX_ANOMALIES=3
CLOCK_SKEW_TOLERANCE_SECONDS=300
ERROR_BUDGET_LOCK_THRESHOLD_PROD=1.0
ERROR_BUDGET_LOCK_THRESHOLD_STAGING=10.0
DEBUG=false

# Override mock dependency states (for integration tests)
MOCK_S3_AUDIT_STATUS=connected
MOCK_BEDROCK_STATUS=accessible
MOCK_S3_CUR_STATUS=reachable
